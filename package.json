{
  "name": "changelog-collect-action",
  "version": "1.0.0",
  "description": "Collects commit range diffs and outputs a structured changeset.v1.json",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --sourcemap",
    "test": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "github-action",
    "changelog",
    "diff",
    "commits"
  ],
  "author": "marco-jardim",
  "license": "GPL-3.0",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@octokit/rest": "^22.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
